{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "Represents a physical retail store location.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the store" },
        "address": { "type": "string", "description": "Full address of the store" }
      },
      "required": ["name", "address"]
    },
    "Product": {
      "title": "Product",
      "description": "Represents a product in the catalog.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the product" },
        "category": { "type": "string", "description": "Product category (e.g., Electronics, Clothing)" },
        "price": { "type": "number", "description": "Unit price of the product" },
        "sku": { "type": "string", "description": "Unique Stock Keeping Unit identifier" }
      },
      "required": ["name", "category", "price", "sku"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Tracks stock levels of a product at a specific store.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to the Product ID" },
        "storeId": { "type": "string", "description": "Reference to the Store ID" },
        "stockLevel": { "type": "integer", "description": "Current quantity in stock" }
      },
      "required": ["productId", "storeId", "stockLevel"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Represents a retail customer.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Customer's full name" },
        "email": { "type": "string", "description": "Customer's email address" },
        "phone": { "type": "string", "description": "Customer's phone number" }
      },
      "required": ["name", "email", "phone"]
    },
    "Order": {
      "title": "Order",
      "description": "Represents a customer order.",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "Reference to the Customer ID" },
        "storeId": { "type": "string", "description": "Reference to the Store ID" },
        "totalPrice": { "type": "number", "description": "Aggregate price of all items in the order" },
        "date": { "type": "string", "format": "date-time", "description": "Timestamp of the order" }
      },
      "required": ["customerId", "storeId", "totalPrice", "date"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "Represents an individual item within an order.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string", "description": "Reference to the Order ID" },
        "productId": { "type": "string", "description": "Reference to the Product ID" },
        "quantity": { "type": "integer", "description": "Quantity purchased" },
        "price": { "type": "number", "description": "Price at the time of purchase" }
      },
      "required": ["orderId", "productId", "quantity", "price"]
    },
    "Review": {
      "title": "Review",
      "description": "A customer review for a product at a store (Unstructured/NoSQL format).",
      "type": "object",
      "properties": {
        "customerId": { "type": "string", "description": "Reference to the Customer ID" },
        "productId": { "type": "string", "description": "Reference to the Product ID" },
        "storeId": { "type": "string", "description": "Reference to the Store ID" },
        "rating": { "type": "integer", "description": "Star rating (1-5)" },
        "comment": { "type": "string", "description": "Optional customer feedback" }
      },
      "required": ["customerId", "productId", "storeId", "rating"]
    }
  },
  "firestore": {
    "stores": {
      "schema": "Store",
      "description": "Global list of physical store locations."
    },
    "products": {
      "schema": "Product",
      "description": "Master product catalog."
    },
    "inventory": {
      "schema": "Inventory",
      "description": "Stock tracking across stores (Mapping collection)."
    },
    "customers": {
      "schema": "Customer",
      "description": "Customer database."
    },
    "orders": {
      "schema": "Order",
      "description": "Customer order records."
    },
    "orderItems": {
      "schema": "OrderItem",
      "description": "Line items for every order."
    },
    "reviews": {
      "schema": "Review",
      "description": "Product reviews and feedback."
    }
  }
}
